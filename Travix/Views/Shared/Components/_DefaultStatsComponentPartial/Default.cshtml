<section class="py-lg max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-gutter">

        <div class="bg-white p-6 rounded-card hotel-card-shadow flex flex-col justify-between border border-slate-100">
            <div class="flex justify-between items-start">
                <span class="material-symbols-outlined text-secondary-container text-3xl">wb_sunny</span>
                <span class="text-xs font-bold text-slate-400">HAVA DURUMU</span>
            </div>
            <div>
                <h3 class="text-headline-md font-headline-md mt-4">@ViewBag.Temp°C</h3>
                <p class="text-body-sm text-slate-600">Antalya, @ViewBag.Desc</p>
            </div>
        </div>

        <div class="bg-white p-6 rounded-card hotel-card-shadow flex flex-col justify-between border border-slate-100">
            <div class="flex justify-between items-start">
                <span class="material-symbols-outlined text-green-500 text-3xl">attach_money</span>
                <span class="text-xs font-bold text-slate-400">DOLAR</span>
            </div>
            <div>
                <h3 class="text-headline-md font-headline-md mt-4">@ViewBag.UsdTry TL</h3>
                <p class="text-body-sm text-slate-600">USD/TRY</p>
            </div>
        </div>

        <div class="bg-white p-6 rounded-card hotel-card-shadow flex flex-col justify-between border border-slate-100">
            <div class="flex justify-between items-start">
                <span class="material-symbols-outlined text-blue-500 text-3xl">euro</span>
                <span class="text-xs font-bold text-slate-400">EURO</span>
            </div>
            <div>
                <h3 class="text-headline-md font-headline-md mt-4">@ViewBag.EurTry TL</h3>
                <p class="text-body-sm text-slate-600">EUR/TRY</p>
            </div>
        </div>

        <div class="bg-white p-6 rounded-card hotel-card-shadow flex flex-col justify-between border border-slate-100">
            <div class="flex justify-between items-start">
                <span class="material-symbols-outlined text-red-400 text-3xl">local_gas_station</span>
                <span class="text-xs font-bold text-slate-400">BENZİN</span>
            </div>
            <div>
                <h3 class="text-headline-md font-headline-md mt-4">@ViewBag.GasolinePrice TL</h3>
                <p class="text-body-sm text-slate-600">Benzin (Litre)</p>
            </div>
        </div>

        <div class="bg-slate-900 text-white p-6 rounded-card shadow-xl flex flex-col justify-between">
            <div class="flex justify-between items-start">
                <span class="material-symbols-outlined text-secondary-container text-3xl">lightbulb</span>
                <span class="text-xs font-bold text-slate-400">GÜNÜN TÜYOSU</span>
            </div>
            <p class="text-body-sm font-medium mt-4">
                Vize randevunuzu seyahatten en az 60 gün önce alın.
            </p>
        </div>

    </div>
</section>