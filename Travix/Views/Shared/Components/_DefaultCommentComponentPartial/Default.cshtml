@model List<Travix.Dtos.AdminDtos.CommentDtos.ResultCommentDto>

<section class="py-xl bg-white overflow-hidden relative">
    <div class="absolute -right-20 top-0 w-96 h-96 bg-secondary-fixed/30 rounded-full blur-3xl -z-0"></div>

    <div class="max-w-7xl mx-auto px-8 relative z-10 text-center">
        <h2 class="text-headline-lg font-headline-lg text-slate-900 mb-lg">
            Misafirlerimizin Deneyimleri
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
            @{
                var index = 0;
            }

            @foreach (var item in Model.Where(x => x.IsStatus).Take(3))
            {
                var isFeatured = index == 1;

                <div class="@(isFeatured 
                    ? "bg-slate-900 text-white p-10 rounded-card shadow-2xl text-left scale-105 z-10" 
                    : "bg-white p-10 rounded-card hotel-card-shadow border border-slate-100 text-left")">

                    <div class="flex text-secondary-container mb-6">
                        @for (int i = 0; i < 5; i++)
                        {
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">
                                star
                            </span>
                        }
                    </div>

                    <p class="text-body-lg @(isFeatured ? "text-white/90" : "text-slate-700") italic mb-10 leading-relaxed">
                        "@item.CommantText"
                    </p>

                    <div class="flex items-center">
                        <img class="w-14 h-14 rounded-full object-cover border-2 @(isFeatured ? "border-slate-700" : "border-white") shadow-md mr-4"
                             src="@item.ImageUrl"
                             alt="@item.NameSurname" />

                        <div>
                            <h4 class="font-label-bold @(isFeatured ? "text-white" : "text-slate-900")">
                                @item.NameSurname
                            </h4>

                            <span class="text-body-sm text-slate-400">
                                @item.Title
                            </span>
                        </div>
                    </div>
                </div>

                index++;
            }
        </div>
    </div>
</section>