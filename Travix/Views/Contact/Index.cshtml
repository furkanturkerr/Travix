@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
@await Component.InvokeAsync("_ListHeadComponentPartial")

<body class="bg-[#F8FAFC]">
@await Component.InvokeAsync("_DefaultHeaderComponentPartial")

<section class="pt-32 pb-20 bg-[#F8FAFC] border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-8">
        <span class="inline-flex items-center rounded-full bg-orange-100 text-orange-600 px-4 py-2 text-xs font-bold uppercase mb-6">
            Travix İletişim
        </span>

        <h1 class="text-5xl md:text-6xl font-black text-[#0F172A] mb-4 leading-tight">
            Bizimle iletişime geç
        </h1>

        <p class="text-lg text-slate-500 max-w-2xl leading-relaxed">
            Soruların mı var? Travix ekibi sana yardımcı olmak için burada.
        </p>
    </div>
</section>

<section class="py-20 bg-[#F8FAFC]">
    <div class="max-w-7xl mx-auto px-8">

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

            <div class="lg:col-span-7">
                <div class="bg-white rounded-[28px] p-10 border border-slate-100 shadow-[0_20px_60px_rgba(15,23,42,0.06)]">
                    <h2 class="text-3xl font-black text-[#0F172A] mb-8">
                        Mesaj Gönder
                    </h2>

                    <form class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <input type="text" placeholder="Ad Soyad"
                                   class="w-full border border-slate-200 rounded-xl p-4 focus:ring-2 focus:ring-orange-400 outline-none" />
                            <input type="email" placeholder="E-posta"
                                   class="w-full border border-slate-200 rounded-xl p-4 focus:ring-2 focus:ring-orange-400 outline-none" />
                        </div>

                        <input type="text" placeholder="Konu"
                               class="w-full border border-slate-200 rounded-xl p-4 focus:ring-2 focus:ring-orange-400 outline-none" />

                        <textarea rows="6" placeholder="Mesajınız..."
                                  class="w-full border border-slate-200 rounded-xl p-4 focus:ring-2 focus:ring-orange-400 outline-none"></textarea>

                        <button type="submit"
                                class="bg-[#0F172A] text-white px-8 py-4 rounded-xl font-semibold hover:-translate-y-0.5 transition">
                            Gönder
                        </button>
                    </form>
                </div>
            </div>

            <div class="lg:col-span-5 space-y-6">
                <div class="bg-white rounded-[28px] p-8 border border-slate-100 shadow-[0_20px_60px_rgba(15,23,42,0.06)]">
                    <h3 class="text-2xl font-black text-[#0F172A] mb-6">
                        İletişim Bilgileri
                    </h3>

                    <div class="space-y-5 text-slate-600">
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-orange-500">mail</span>
                            support@travix.com
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-orange-500">call</span>
                            +90 555 123 45 67
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-orange-500">location_on</span>
                            İstanbul, Türkiye
                        </div>
                    </div>
                </div>

                <div class="bg-[#0F172A] text-white rounded-[28px] p-8 shadow-[0_20px_60px_rgba(15,23,42,0.14)]">
                    <h3 class="text-2xl font-black mb-3">
                        Hızlı Destek
                    </h3>

                    <p class="text-slate-300 mb-6">
                        En kısa sürede sana dönüş yapıyoruz.
                    </p>

                    <button class="bg-white text-[#0F172A] px-6 py-3 rounded-xl font-semibold">
                        Canlı Destek
                    </button>
                </div>
            </div>

        </div>
    </div>
</section>

@await Component.InvokeAsync("_DefaultFooterComponentPartial")
</body>
</html>