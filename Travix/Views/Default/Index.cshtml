@model dynamic

@{
    Layout = null;
}

<html class="scroll-smooth" lang="tr">
@await Component.InvokeAsync("_DefaultHeadComponentPartial")

<body class="bg-[#F8FAFC] font-body-md text-on-background">

@await Component.InvokeAsync("_DefaultHeaderComponentPartial")

<section class="relative min-h-[960px] w-full flex items-center pt-28 pb-28 overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img alt="Luxury hotel with sea view" class="w-full h-full object-cover scale-[1.02]" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCt-RZWe6FUPDqj2_7z7MhJDDOYwDWqhRw9c02qo1IKJ_EQ899MdkxIuuTrmnL5BKWtf6e71tMHuID8D5q0JUC_9bRJLYS6kQ9bZm5pGOUtlXxa1bSfMQT1BGduBcLonLpcBaANmTGn85TqUw68xW219QXKCnwVqZHzW-aZbW0rKfT81rt9lzuGE0SGoyOGQNzjCsgmH3QI6B9Gi6kA0wwoWK3x0MUT3q1gf0zNHzQR3xJ2JcAdQgVEYEp8-uRiiFPPalJ27DUhjV0"/>
        <div class="absolute inset-0 hero-gradient"></div>
        <div class="absolute inset-x-0 bottom-[-120px] h-[360px] 
            bg-gradient-to-t from-[#F8FAFC] via-[#F8FAFC]/45 via-45% to-transparent 
            pointer-events-none">
        </div>
    </div>

    <div class="absolute top-32 right-12 hidden xl:block hero-soft-card hero-float rounded-[28px] p-5 text-white w-72 z-10">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-11 h-11 rounded-2xl bg-white/15 flex items-center justify-center">
                <span class="material-symbols-outlined text-secondary-container">hotel_class</span>
            </div>
            <div>
                <p class="text-sm text-white/65">Bugünün önerisi</p>
                <h3 class="font-bold">Milano şehir merkezi</h3>
            </div>
        </div>
        <div class="flex items-center justify-between text-sm text-white/75">
            <span>8.7+ puanlı oteller</span>
            <span class="text-secondary-container font-bold">20 sonuç</span>
        </div>
    </div>

    <div class="absolute right-24 bottom-36 hidden xl:flex hero-soft-card hero-float-delay rounded-full px-5 py-3 text-white items-center gap-3 z-10">
        <span class="material-symbols-outlined text-secondary-container">bolt</span>
        <span class="text-sm font-semibold">Canlı API verileriyle hızlı arama</span>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-8 w-full">
        <div class="max-w-4xl text-left">
            <div class="max-w-3xl text-left">
                <span class="fade-up inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-2 text-sm font-medium text-white backdrop-blur-md border border-white/20 mb-6">
                    <span class="w-2 h-2 rounded-full bg-secondary-container shadow-[0_0_18px_rgba(254,166,25,.8)]"></span>
                    Travix ile akıllı otel arama
                </span>

                <h1 class="fade-up fade-up-delay-1 text-white text-5xl md:text-6xl font-bold leading-tight tracking-tight mb-6 font-body-md">
                    Seyahatin için en uygun oteli kolayca bul.
                </h1>

                <p class="fade-up fade-up-delay-2 text-white/85 text-lg md:text-xl leading-relaxed max-w-2xl mb-10">
                    Şehir, tarih ve misafir bilgilerini gir; yurt dışındaki otelleri fiyat, konum ve puana göre hızlıca keşfet.
                </p>
            </div>

            <div class="fade-up fade-up-delay-3 w-full max-w-[1120px] search-shell rounded-[28px] p-6 md:p-8 mb-10">
                <form method="post" asp-controller="Hotel" asp-action="List" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
                        <div class="search-field flex flex-col space-y-2 rounded-2xl border border-slate-100 bg-slate-50/80 p-1">
                            <label class="text-xs font-bold text-slate-500 uppercase tracking-widest px-3 pt-2">Şehir</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">location_on</span>
                                <input name="city" class="w-full pl-12 pr-4 py-3 bg-transparent border-0 focus:ring-0 text-slate-900 font-semibold placeholder:text-slate-400" placeholder="Milano, Paris, Prag" type="text" required/>
                            </div>
                        </div>
                        <div class="search-field flex flex-col space-y-2 rounded-2xl border border-slate-100 bg-slate-50/80 p-1">
                            <label class="text-xs font-bold text-slate-500 uppercase tracking-widest px-3 pt-2">Giriş Tarihi</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">calendar_today</span>
                                <input name="checkIn" class="w-full pl-12 pr-4 py-3 bg-transparent border-0 focus:ring-0 text-slate-900 font-semibold" type="date" required/>
                            </div>
                        </div>
                        <div class="search-field flex flex-col space-y-2 rounded-2xl border border-slate-100 bg-slate-50/80 p-1">
                            <label class="text-xs font-bold text-slate-500 uppercase tracking-widest px-3 pt-2">Çıkış Tarihi</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">calendar_today</span>
                                <input name="checkOut" class="w-full pl-12 pr-4 py-3 bg-transparent border-0 focus:ring-0 text-slate-900 font-semibold" type="date" required/>
                            </div>
                        </div>
                        <div class="search-field flex flex-col space-y-2 rounded-2xl border border-slate-100 bg-slate-50/80 p-1">
                            <label class="text-xs font-bold text-slate-500 uppercase tracking-widest px-3 pt-2">Yetişkin</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">person</span>
                                <select name="adults" class="w-full pl-12 pr-4 py-3 bg-transparent border-0 focus:ring-0 text-slate-900 font-semibold appearance-none">
                                    <option value="1">1 Yetişkin</option>
                                    <option value="2" selected>2 Yetişkin</option>
                                    <option value="3">3 Yetişkin</option>
                                    <option value="4">4 Yetişkin</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-5 items-end">
                        <div class="search-field flex flex-col space-y-2 rounded-2xl border border-slate-100 bg-slate-50/80 p-1">
                            <label class="text-xs font-bold text-slate-500 uppercase tracking-widest px-3 pt-2">Para Birimi</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">payments</span>
                                <select name="currency" class="w-full pl-12 pr-4 py-3 bg-transparent border-0 focus:ring-0 text-slate-900 font-semibold appearance-none">
                                    <option value="AED" selected>AED</option>
                                    <option value="USD">USD</option>
                                    <option value="EUR">EUR</option>
                                    <option value="TRY">TRY</option>
                                    <option value="GBP">GBP</option>
                                </select>
                            </div>
                        </div>
                        <div class="search-field flex flex-col space-y-2 rounded-2xl border border-slate-100 bg-slate-50/80 p-1">
                            <label class="text-xs font-bold text-slate-500 uppercase tracking-widest px-3 pt-2">Dil</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">language</span>
                                <select name="language" class="w-full pl-12 pr-4 py-3 bg-transparent border-0 focus:ring-0 text-slate-900 font-semibold appearance-none">
                                    <option value="en-us" selected>İngilizce</option>
                                    <option value="tr">Türkçe</option>
                                    <option value="de">Almanca</option>
                                </select>
                            </div>
                        </div>
                        <div class="search-field flex flex-col space-y-2 rounded-2xl border border-slate-100 bg-slate-50/80 p-1">
                            <label class="text-xs font-bold text-slate-500 uppercase tracking-widest px-3 pt-2">Oda</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">bed</span>
                                <select name="room" class="w-full pl-12 pr-4 py-3 bg-transparent border-0 focus:ring-0 text-slate-900 font-semibold appearance-none">
                                    <option value="1" selected>1 Oda</option>
                                    <option value="2">2 Oda</option>
                                    <option value="3">3 Oda</option>
                                </select>
                            </div>
                        </div>
                        <button class="w-full h-[64px] bg-gradient-to-r from-[#fea619] to-[#ff8a00] text-white rounded-2xl font-bold hover:shadow-[0_18px_40px_rgba(254,166,25,.35)] hover:-translate-y-0.5 active:scale-[.98] transition-all flex items-center justify-center shadow-lg group" type="submit">
                            <span class="material-symbols-outlined mr-2 transition-transform group-hover:scale-110">search</span>
                            OTEL ARA
                        </button>
                    </div>
                </form>
            </div>

            <div class="flex flex-wrap gap-3 items-center mt-8">
                <div class="inline-flex items-center rounded-full bg-white/15 px-4 py-2 text-sm font-medium text-white backdrop-blur-md border border-white/20">
                    <span class="w-2 h-2 rounded-full bg-secondary-container mr-2"></span>
                    Yurt dışı şehirlerde otel arama
                </div>

                <div class="inline-flex items-center rounded-full bg-white/15 px-4 py-2 text-sm font-medium text-white backdrop-blur-md border border-white/20">
                    <span class="material-symbols-outlined text-secondary-container text-[18px] mr-2">payments</span>
                    Fiyat ve puan karşılaştırma
                </div>

                <div class="inline-flex items-center rounded-full bg-white/15 px-4 py-2 text-sm font-medium text-white backdrop-blur-md border border-white/20">
                    <span class="material-symbols-outlined text-secondary-container text-[18px] mr-2">hotel</span>
                    Otel kartlarıyla hızlı inceleme
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-lg max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-gutter">
        <div class="bg-white p-6 rounded-card hotel-card-shadow flex flex-col justify-between border border-slate-100">
            <div class="flex justify-between items-start">
                <span class="material-symbols-outlined text-secondary-container text-3xl">wb_sunny</span>
                <span class="text-xs font-bold text-slate-400">HAVA DURUMU</span>
            </div>
            <div>
                <h3 class="text-headline-md font-headline-md mt-4">24°C</h3>
                <p class="text-body-sm text-slate-600">Antalya, Güneşli</p>
            </div>
        </div>
        <div class="bg-white p-6 rounded-card hotel-card-shadow flex flex-col justify-between border border-slate-100">
            <div class="flex justify-between items-start">
                <span class="material-symbols-outlined text-green-500 text-3xl">currency_exchange</span>
                <span class="text-xs font-bold text-slate-400">KUR</span>
            </div>
            <div>
                <h3 class="text-headline-md font-headline-md mt-4">32.40 TL</h3>
                <p class="text-body-sm text-slate-600">USD/TRY</p>
            </div>
        </div>
        <div class="bg-white p-6 rounded-card hotel-card-shadow flex flex-col justify-between border border-slate-100">
            <div class="flex justify-between items-start">
                <span class="material-symbols-outlined text-red-400 text-3xl">local_gas_station</span>
                <span class="text-xs font-bold text-slate-400">YAKIT</span>
            </div>
            <div>
                <h3 class="text-headline-md font-headline-md mt-4">42.15 TL</h3>
                <p class="text-body-sm text-slate-600">Benzin (Litre)</p>
            </div>
        </div>
        <div class="bg-white p-6 rounded-card hotel-card-shadow flex flex-col justify-between border border-slate-100">
            <div class="flex justify-between items-start">
                <span class="material-symbols-outlined text-amber-500 text-3xl" style="font-variation-settings: 'FILL' 1;">currency_bitcoin</span>
                <span class="text-xs font-bold text-slate-400">KRİPTO</span>
            </div>
            <div>
                <h3 class="text-headline-md font-headline-md mt-4">$64,210</h3>
                <p class="text-body-sm text-slate-600">Bitcoin BTC</p>
            </div>
        </div>
        <div class="bg-slate-900 text-white p-6 rounded-card shadow-xl flex flex-col justify-between">
            <div class="flex justify-between items-start">
                <span class="material-symbols-outlined text-secondary-container text-3xl">lightbulb</span>
                <span class="text-xs font-bold text-slate-400">GÜNÜN TÜYOSU</span>
            </div>
            <p class="text-body-sm font-medium mt-4">Vize randevunuzu seyahatten en az 60 gün önce alın.</p>
        </div>
    </div>
</section>
<!-- 4. Popüler Destinasyonlar -->
