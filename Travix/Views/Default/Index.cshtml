        </div>
        <div class="relative rounded-card overflow-hidden group">
            <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD_nnI3srpqxAghIFwvT1wGRH3mu4tj8Ax0xvUWnos8uNqFFRvrD6zMWlXVckqn5Qx7Nu1Vt8ErDKd3oVaJRJBtZB0I0rGujvI9zJX94k6gWqdnQXbkfm0JmilZFwJYPjAfTakeZy_flgmMgiLy7mimVAOMI5_zDUkKMiaZ_xk5xAFNnsdjCB89C_iXiB23d0q-h7pujMK7sUMee3FYcSOq69FxAUKd1_gGtCd2NBgXBYHmvHd5ugacmobZxjAhObjnIM0Ug2KJV2c"/>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
