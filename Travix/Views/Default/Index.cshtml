<!-- 5. Öne Çıkan Oteller -->
@await Component.InvokeAsync("_DefaultHotelComponentPartial")
<!-- 6. Otel Detay Önizleme -->
<section class="py-xl max-w-7xl mx-auto px-8">
    <div class="bg-white rounded-[40px] overflow-hidden flex flex-col md:flex-row hotel-card-shadow min-h-[600px] border border-slate-100">

        <!-- SOL GÖRSEL -->
        <div class="md:w-1/2 relative">
            <img class="w-full h-full object-cover"
                 src="https://images.unsplash.com/photo-1501117716987-c8e1ecb210c1?q=80&w=1600&auto=format&fit=crop" />
            <div class="absolute inset-0 bg-black/30"></div>
        </div>

        <!-- SAĞ İÇERİK -->
        <div class="md:w-1/2 p-lg flex flex-col justify-center">

            <span class="inline-block bg-secondary-fixed text-secondary font-label-bold px-4 py-1 rounded-full text-xs mb-6 w-fit uppercase">
                Hakkımızda
            </span>

            <h2 class="text-display-xl font-display-xl text-slate-900 mb-6">
                Travix ile seyahat artık daha akıllı
            </h2>

            <p class="text-body-lg text-slate-600 mb-8 leading-relaxed">
                Travix, dünyanın dört bir yanındaki otelleri tek platformda sunan modern bir seyahat çözümüdür.
                Amacımız; kullanıcıların en uygun fiyatlı, en yüksek puanlı ve en doğru oteli kolayca bulmasını sağlamaktır.
                Gelişmiş filtreleme sistemi ve gerçek zamanlı API verileri ile karar sürecinizi hızlandırır.
            </p>

            <!-- ÖZELLİKLER -->
            <div class="grid grid-cols-2 gap-6 mb-10">

                <div class="flex items-center space-x-3">
                    <span class="material-symbols-outlined text-secondary-container">travel_explore</span>
                    <span class="text-body-md font-semibold">Global Otel Verisi</span>
                </div>

                <div class="flex items-center space-x-3">
                    <span class="material-symbols-outlined text-secondary-container">bolt</span>
                    <span class="text-body-md font-semibold">Hızlı Arama Deneyimi</span>
                </div>

                <div class="flex items-center space-x-3">
                    <span class="material-symbols-outlined text-secondary-container">monitoring</span>
                    <span class="text-body-md font-semibold">Canlı Fiyat Takibi</span>
                </div>

                <div class="flex items-center space-x-3">
                    <span class="material-symbols-outlined text-secondary-container">filter_alt</span>
                    <span class="text-body-md font-semibold">Akıllı Filtreleme</span>
                </div>

            </div>

            <!-- CTA -->
            <div class="flex items-center space-x-6">
                <a href="/Hotel/List"
                   class="bg-slate-900 text-white px-10 py-5 rounded-2xl font-label-bold hover:scale-105 transition-all shadow-xl">
                    Otel Ara
                </a>

                <div class="text-slate-900">
                    <span class="block text-xs font-bold text-slate-400 uppercase">
                        PLATFORM
                    </span>
                    <span class="text-headline-lg font-headline-lg">
                        Travix
                    </span>
                </div>
            </div>

        </div>
    </div>
</section>
<!-- 7. Nasıl Çalışır -->
<section class="py-xl bg-white">
    <div class="max-w-7xl mx-auto px-8 text-center">
        <h2 class="text-headline-lg font-headline-lg text-slate-900 mb-lg">Tatilinizi Planlamak Çok Kolay</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16 relative">
            <div class="hidden md:block absolute top-1/3 left-1/4 right-1/4 h-px border-t-2 border-dashed border-slate-200 -z-0"></div>
            <div class="relative z-10 flex flex-col items-center">
                <div class="w-24 h-24 bg-slate-50 rounded-[32px] flex items-center justify-center mb-8 shadow-inner border border-slate-100">
                    <span class="material-symbols-outlined text-slate-900 text-4xl">search</span>
                </div>
                <h3 class="text-headline-md font-headline-md mb-4">Ara</h3>
                <p class="text-body-md text-slate-500">Hayalinizdeki destinasyonu ve tarihleri belirleyerek aramanızı başlatın.</p>
            </div>
            <div class="relative z-10 flex flex-col items-center">
                <div class="w-24 h-24 bg-secondary-container rounded-[32px] flex items-center justify-center mb-8 shadow-xl">
                    <span class="material-symbols-outlined text-white text-4xl">compare_arrows</span>
                </div>
                <h3 class="text-headline-md font-headline-md mb-4">Karşılaştır</h3>
                <p class="text-body-md text-slate-500">Yüzlerce seçenek arasından bütçenize ve zevkinize en uygun olanı seçin.</p>
            </div>
            <div class="relative z-10 flex flex-col items-center">
                <div class="w-24 h-24 bg-slate-50 rounded-[32px] flex items-center justify-center mb-8 shadow-inner border border-slate-100">
                    <span class="material-symbols-outlined text-slate-900 text-4xl">verified_user</span>
                </div>
                <h3 class="text-headline-md font-headline-md mb-4">İncele ve Al</h3>
                <p class="text-body-md text-slate-500">Güvenli ödeme yöntemleriyle saniyeler içinde rezervasyonunuzu tamamlayın.</p>
            </div>
        </div>
    </div>
</section>
<!-- 8. Blog -->
<section class="py-xl bg-slate-50">
    <div class="max-w-7xl mx-auto px-8">
        <div class="flex justify-between items-end mb-lg">
            <div>
                <h2 class="text-headline-lg font-headline-lg text-slate-900">Seyahat Rehberi</h2>
                <p class="text-body-lg text-slate-500 mt-2">Seyahatiniz öncesi ilham alabileceğiniz ipuçları ve rehberler.</p>
            </div>
            <button class="bg-white text-slate-900 font-label-bold px-6 py-3 rounded-xl border border-slate-200 hover:bg-slate-100 transition-colors">Tüm Yazılar</button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
