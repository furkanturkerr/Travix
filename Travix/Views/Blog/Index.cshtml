@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">

@await Component.InvokeAsync("_DefaultHeadComponentPartial")

<body class="bg-background font-body-md text-on-background">

@await Component.InvokeAsync("_DefaultHeaderComponentPartial")

<section class="relative h-[360px] flex items-center justify-center overflow-hidden">
    <img src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&q=80&w=1800"
         class="absolute inset-0 w-full h-full object-cover"
         alt="Travix Blog" />

    <div class="absolute inset-0 bg-black/50"></div>

    <div class="relative z-10 text-center px-6">
        <span class="inline-flex items-center rounded-full bg-secondary-fixed text-secondary px-4 py-2 text-xs font-label-bold uppercase mb-5">
            Travix Blog
        </span>

        <h1 class="text-5xl md:text-6xl font-headline-lg text-white mb-4">
            Seyahatin Yeni Hikayesi
        </h1>

        <p class="text-white/85 text-body-lg max-w-2xl mx-auto">
            En iyi oteller, gizli kalmış destinasyonlar ve unutulmaz deneyimler için hazırlanan özel rehberleri keşfet.
        </p>
    </div>
</section>

<section class="py-xl bg-background">
    <div class="max-w-7xl mx-auto px-8">

        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-lg">
            <div>
                <h2 class="text-headline-lg font-headline-lg text-primary mb-3">
                    Seyahat Rehberi
                </h2>

                <p class="text-body-lg text-on-surface-variant">
                    Seyahatiniz öncesi ilham alabileceğiniz ipuçları ve rehberler.
                </p>
            </div>

            <a href="#"
               class="bg-white border border-outline-variant text-primary px-8 py-4 rounded-xl font-label-bold hover:border-secondary-container hover:text-secondary transition-all">
                Tüm Yazılar
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">

            <article class="bg-white rounded-card overflow-hidden hotel-card-shadow border border-slate-100 group">
                <div class="h-64 overflow-hidden">
                    <div class="w-full h-full bg-gradient-to-br from-secondary-fixed via-[#8fc8bd] to-[#3d8d86] group-hover:scale-105 transition-transform duration-700"></div>
                </div>

                <div class="p-8">
                    <div class="flex items-center text-xs font-label-bold text-secondary-container mb-4 uppercase tracking-widest">
                        <span class="material-symbols-outlined text-sm mr-2">calendar_today</span>
                        12 Haziran 2024
                    </div>

                    <h3 class="text-headline-md font-headline-md text-primary mb-4 leading-tight">
                        Avrupa'da Unutulmaz Bir Gurme Turu İçin 5 Şehir
                    </h3>

                    <p class="text-body-sm text-on-surface-variant mb-6 leading-relaxed">
                        Mutfak kültürünün zirvesinde bir yolculuğa çıkmaya hazır mısınız? İşte lezzet duraklarınız...
                    </p>

                    <a href="#" class="font-label-bold text-primary flex items-center hover:text-secondary-container transition-colors">
                        Devamını Oku
                        <span class="material-symbols-outlined ml-1 text-sm">arrow_forward</span>
                    </a>
                </div>
            </article>

            <article class="bg-white rounded-card overflow-hidden hotel-card-shadow border border-slate-100 group">
                <div class="h-64 overflow-hidden">
                    <div class="w-full h-full bg-gradient-to-br from-[#2f8f8d] via-secondary-fixed to-secondary-container group-hover:scale-105 transition-transform duration-700"></div>
                </div>

                <div class="p-8">
                    <div class="flex items-center text-xs font-label-bold text-secondary-container mb-4 uppercase tracking-widest">
                        <span class="material-symbols-outlined text-sm mr-2">calendar_today</span>
                        08 Haziran 2024
                    </div>

                    <h3 class="text-headline-md font-headline-md text-primary mb-4 leading-tight">
                        Boutique Otel Seçerken Dikkat Etmeniz Gerekenler
                    </h3>

                    <p class="text-body-sm text-on-surface-variant mb-6 leading-relaxed">
                        Lüksü butik bir atmosferde yaşamak isteyenler için doğru seçim rehberi burada.
                    </p>

                    <a href="#" class="font-label-bold text-primary flex items-center hover:text-secondary-container transition-colors">
                        Devamını Oku
                        <span class="material-symbols-outlined ml-1 text-sm">arrow_forward</span>
                    </a>
                </div>
            </article>

            <article class="bg-white rounded-card overflow-hidden hotel-card-shadow border border-slate-100 group">
                <div class="h-64 overflow-hidden">
                    <div class="w-full h-full bg-gradient-to-br from-primary-fixed-dim via-[#91c9be] to-secondary-fixed group-hover:scale-105 transition-transform duration-700"></div>
                </div>

                <div class="p-8">
                    <div class="flex items-center text-xs font-label-bold text-secondary-container mb-4 uppercase tracking-widest">
                        <span class="material-symbols-outlined text-sm mr-2">calendar_today</span>
                        05 Haziran 2024
                    </div>

                    <h3 class="text-headline-md font-headline-md text-primary mb-4 leading-tight">
                        Vahşi Doğada Lüks: En İyi Safari Destinasyonları
                    </h3>

                    <p class="text-body-sm text-on-surface-variant mb-6 leading-relaxed">
                        Macera ve konforun buluştuğu dünyanın en özel safari bölgelerini sizin için derledik.
                    </p>

                    <a href="#" class="font-label-bold text-primary flex items-center hover:text-secondary-container transition-colors">
                        Devamını Oku
                        <span class="material-symbols-outlined ml-1 text-sm">arrow_forward</span>
                    </a>
                </div>
            </article>

        </div>
    </div>
</section>

@await Component.InvokeAsync("_DefaultFooterComponentPartial")

</body>
</html>