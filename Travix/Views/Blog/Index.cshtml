@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
@await Component.InvokeAsync("_ListHeadComponentPartial")

<body class="bg-[#F8FAFC]">
@await Component.InvokeAsync("_DefaultHeaderComponentPartial")

<section class="pt-32 pb-20 bg-[#F8FAFC] border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-8">
        <span class="inline-flex items-center rounded-full bg-orange-100 text-orange-600 px-4 py-2 text-xs font-bold uppercase mb-6">
            Travix Blog
        </span>

        <h1 class="text-5xl md:text-6xl font-black text-[#0F172A] mb-4 leading-tight">
            Seyahat Rehberi
        </h1>

        <p class="text-lg text-slate-500 max-w-2xl leading-relaxed">
            Otel seçimi, şehir rehberleri ve seyahat ipuçlarıyla daha bilinçli seyahat edin.
        </p>
    </div>
</section>

<section class="py-20 bg-[#F8FAFC]">
    <div class="max-w-7xl mx-auto px-8">

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

            <div class="lg:col-span-4">
                <div class="bg-white rounded-[28px] p-8 border border-slate-100 shadow-[0_20px_60px_rgba(15,23,42,0.06)] sticky top-28">
                    <span class="material-symbols-outlined text-orange-500 text-4xl mb-5">auto_stories</span>

                    <h2 class="text-3xl font-black text-[#0F172A] mb-3">
                        Son Yazılar
                    </h2>

                    <p class="text-slate-500 leading-relaxed mb-8">
                        Seyahatinizi daha iyi planlamanız için seçilmiş rehberler ve pratik öneriler.
                    </p>

                    <div class="flex flex-wrap gap-2">
                        <button class="px-5 py-2 rounded-full bg-[#0F172A] text-white text-sm font-semibold">Tümü</button>
                        <button class="px-5 py-2 rounded-full bg-slate-50 text-slate-600 text-sm font-semibold border border-slate-200">Otel</button>
                        <button class="px-5 py-2 rounded-full bg-slate-50 text-slate-600 text-sm font-semibold border border-slate-200">Rehber</button>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-8">

                <article class="group bg-white rounded-[28px] overflow-hidden border border-slate-100 shadow-[0_20px_60px_rgba(15,23,42,0.06)] hover:-translate-y-1 transition-all">
                    <div class="h-64 overflow-hidden">
                        <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                             src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&q=80&w=1200" />
                    </div>
                    <div class="p-7">
                        <div class="text-xs font-bold text-orange-500 uppercase tracking-widest mb-4">12 Haziran 2026</div>
                        <h3 class="text-2xl font-bold text-[#0F172A] mb-4 leading-snug">
                            Avrupa’da İlk Kez Seyahat Edecekler İçin 7 Öneri
                        </h3>
                        <p class="text-slate-500 leading-relaxed mb-7">
                            Şehir seçimi, otel konumu, ulaşım ve bütçe planlaması konusunda seyahatinizi kolaylaştıracak öneriler.
                        </p>
                        <a href="#" class="inline-flex items-center font-bold text-[#0F172A] group-hover:text-orange-600 transition">
                            Devamını Oku
                            <span class="material-symbols-outlined ml-1 text-lg">arrow_forward</span>
                        </a>
                    </div>
                </article>

                <article class="group bg-white rounded-[28px] overflow-hidden border border-slate-100 shadow-[0_20px_60px_rgba(15,23,42,0.06)] hover:-translate-y-1 transition-all">
                    <div class="h-64 overflow-hidden">
                        <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                             src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&q=80&w=1200" />
                    </div>
                    <div class="p-7">
                        <div class="text-xs font-bold text-orange-500 uppercase tracking-widest mb-4">08 Haziran 2026</div>
                        <h3 class="text-2xl font-bold text-[#0F172A] mb-4 leading-snug">
                            Otel Seçerken Nelere Dikkat Etmelisiniz?
                        </h3>
                        <p class="text-slate-500 leading-relaxed mb-7">
                            Konum, yorum sayısı, puan, fiyat ve oda özelliklerini doğru değerlendirerek daha iyi seçim yapabilirsiniz.
                        </p>
                        <a href="#" class="inline-flex items-center font-bold text-[#0F172A] group-hover:text-orange-600 transition">
                            Devamını Oku
                            <span class="material-symbols-outlined ml-1 text-lg">arrow_forward</span>
                        </a>
                    </div>
                </article>

            </div>
        </div>
    </div>
</section>

@await Component.InvokeAsync("_DefaultFooterComponentPartial")
</body>
</html>