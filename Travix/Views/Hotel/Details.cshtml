@model Travix.Dtos.HotelDetailDto

@{
    Layout = null;

    var hotel = Model?.data;

    var hotelName = hotel?.hotel_name ?? "Otel adı bulunamadı";
    var city = hotel?.city ?? "Şehir bilgisi yok";
    var address = hotel?.address ?? "Adres bilgisi bulunamadı";
    var reviewCount = hotel?.review_nr ?? 0;

    var totalPrice = hotel?.product_price_breakdown?.gross_amount?.amount_rounded
                     ?? hotel?.product_price_breakdown?.gross_amount?.value.ToString("0")
                     ?? "Fiyat yok";

    var nightPrice = hotel?.product_price_breakdown?.gross_amount_per_night?.amount_rounded
                     ?? hotel?.product_price_breakdown?.gross_amount_per_night?.value.ToString("0")
                     ?? "Gecelik fiyat yok";

    var currency = hotel?.product_price_breakdown?.gross_amount?.currency ?? "";

    var latitude = hotel?.latitude ?? 0;
    var longitude = hotel?.longitude ?? 0;

    var firstRoom = hotel?.rooms?.Values.FirstOrDefault();
    var photos = firstRoom?.photos ?? new List<Travix.Dtos.HotelDetailDto.Photo>();

    var mainPhoto = photos.FirstOrDefault()?.url_max750
                    ?? photos.FirstOrDefault()?.url_original
                    ?? "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&q=80&w=1600";

    var room = hotel?.block?.FirstOrDefault();
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Travix | @hotelName</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Serif:wght@500;600;700;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

    <style>
        body {
            font-family: Inter, sans-serif;
            background: #F8FAFC;
            color: #0F172A;
        }

        h1, h2, h3, .serif {
            font-family: "Noto Serif", serif;
        }

        .premium-shadow {
            box-shadow: 0 4px 20px -2px rgba(15, 23, 42, 0.08);
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
    </style>
</head>

<body>

@await Component.InvokeAsync("_DefaultHeaderComponentPartial")

<main class="pt-28 pb-20">

    <!-- TITLE -->
    <section class="max-w-7xl mx-auto px-6 mb-8">
        <div class="flex flex-col lg:flex-row justify-between gap-6">
            <div>
                <div class="text-sm text-slate-500 mb-3">
                    Ana Sayfa / @city / @hotelName
                </div>

                <h1 class="serif text-4xl lg:text-5xl font-black mb-4">
                    @hotelName
                </h1>

                <div class="flex flex-wrap items-center gap-5 text-sm text-slate-600">
                    <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-orange-500">location_on</span>
                        @address, @city
                    </div>

                    <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-orange-500">reviews</span>
                        @reviewCount yorum
                    </div>
                </div>
            </div>

            <div class="lg:text-right">
                <div class="text-xs text-slate-500 uppercase font-bold mb-1">
                    Toplam Fiyat
                </div>

                <div class="text-4xl font-black">
                    @totalPrice @currency
                </div>

                <div class="text-sm text-slate-500 mt-1">
                    Gecelik: @nightPrice @currency
                </div>
            </div>
        </div>
    </section>

    <!-- GALLERY -->
    <section class="max-w-7xl mx-auto px-6 mb-12">
        <div class="grid grid-cols-1 md:grid-cols-4 grid-rows-2 gap-3 h-[520px]">

            <div class="md:col-span-2 md:row-span-2 rounded-2xl overflow-hidden">
                <img src="@mainPhoto" class="w-full h-full object-cover" alt="@hotelName"/>
            </div>

            @foreach (var photo in photos.Skip(1).Take(4))
            {
                var photoUrl = photo.url_max750 ?? photo.url_original ?? mainPhoto;

                <div class="hidden md:block rounded-2xl overflow-hidden">
                    <img src="@photoUrl" class="w-full h-full object-cover" alt="@hotelName"/>
                </div>
            }

        </div>
    </section>

    <!-- CONTENT -->
    <section class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- LEFT -->
        <div class="lg:col-span-2 space-y-12">

            <div>
                <h2 class="text-2xl font-bold mb-4">Otel Hakkında</h2>

                <p class="text-slate-600 leading-relaxed">
                    @if (!string.IsNullOrWhiteSpace(firstRoom?.description))
                    {
                        @firstRoom.description
                    }
                    else
                    {
                        <span>
                            @hotelName, @city bölgesinde bulunan bir konaklama seçeneğidir.
                            Otel bilgileri, oda detayları ve fiyat bilgileri API üzerinden alınmaktadır.
                        </span>
                    }
                </p>
            </div>

            <!-- HIGHLIGHTS -->
            @if (hotel?.property_highlight_strip != null && hotel.property_highlight_strip.Any())
            {
                <div>
                    <h3 class="text-2xl font-bold mb-6">Öne Çıkan Özellikler</h3>

                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        @foreach (var item in hotel.property_highlight_strip.Take(8))
                        {
                            <div class="bg-white premium-shadow border border-slate-200 rounded-2xl p-4 text-center">
                                <span class="material-symbols-outlined text-orange-500 mb-2">hotel_class</span>
                                <div class="text-sm font-semibold">@item.name</div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- FACILITIES -->
            @if (hotel?.facilities_block?.facilities != null && hotel.facilities_block.facilities.Any())
            {
                <div>
                    <h3 class="text-2xl font-bold mb-6">Tesis Olanakları</h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        @foreach (var facility in hotel.facilities_block.facilities.Take(10))
                        {
                            <div class="flex items-center gap-3 text-slate-600">
                                <span class="material-symbols-outlined text-green-600">check_circle</span>
                                @facility.name
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- ROOM -->
            @if (room != null)
            {
                <div>
                    <h3 class="text-2xl font-bold mb-6">Oda Bilgisi</h3>

                    <div class="bg-white premium-shadow border border-slate-200 rounded-2xl p-6">
                        <h4 class="text-xl font-bold mb-3">
                            @room.room_name
                        </h4>

                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm text-slate-600">
                            <div>
                                <strong>Yemek Planı:</strong><br/>
                                @room.mealplan
                            </div>

                            <div>
                                <strong>Yetişkin:</strong><br/>
                                @room.nr_adults kişi
                            </div>

                            <div>
                                <strong>İptal:</strong><br/>
                                @(room.refundable == 1 ? "İade edilebilir" : "İade bilgisi yok")
                            </div>
                        </div>

                        @if (room.paymentterms?.cancellation != null)
                        {
                            <div class="mt-5 text-sm text-slate-600">
                                <strong>@room.paymentterms.cancellation.type_translation</strong>
                                <p class="mt-1">@room.paymentterms.cancellation.description</p>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- LOCATION -->
            <div>
                <h3 class="text-2xl font-bold mb-6">Konum</h3>

                <div class="relative h-[360px] rounded-2xl overflow-hidden flex items-center justify-center border border-slate-200 premium-shadow"
                     style="background:
            radial-gradient(circle at 30% 35%, rgba(249,115,22,.18), transparent 28%),
            radial-gradient(circle at 72% 65%, rgba(15,23,42,.08), transparent 30%),
            linear-gradient(135deg, #f8fafc 0%, #e8eef5 45%, #dbe5ef 100%);">

                    <div class="absolute inset-0 bg-white/10"></div>

                    <div class="relative z-10 bg-white/95 backdrop-blur premium-shadow rounded-2xl p-7 text-center max-w-md border border-white">
                        <span class="material-symbols-outlined text-orange-500 text-5xl mb-3">location_on</span>

                        <h4 class="font-bold mb-2 text-[#0F172A]">@hotelName</h4>

                        <p class="text-sm text-slate-500 mb-3">
                            @address, @city
                        </p>

                        <p class="text-xs text-slate-500">
                            Latitude: @latitude / Longitude: @longitude
                        </p>
                    </div>
                </div>
            </div>

        </div>

        <!-- RIGHT CARD -->
        <div class="lg:col-span-1">
            <div class="sticky top-28 bg-white premium-shadow border border-slate-200 rounded-2xl p-8 space-y-6">

                <div class="pb-6 border-b border-slate-200">
                    <div class="text-xs text-slate-500 uppercase font-bold mb-2">
                        Fiyat Bilgisi
                    </div>

                    <div class="text-4xl font-black">
                        @totalPrice @currency
                    </div>

                    <div class="text-sm text-slate-500 mt-1">
                        Gecelik: @nightPrice @currency
                    </div>
                </div>

                <div class="space-y-3 text-sm">
                    <div class="bg-slate-100 rounded-xl p-4">
                        <strong>Otel:</strong><br/>
                        @hotelName
                    </div>

                    <div class="bg-slate-100 rounded-xl p-4">
                        <strong>Şehir:</strong><br/>
                        @city
                    </div>

                    <div class="bg-slate-100 rounded-xl p-4">
                        <strong>Yorum Sayısı:</strong><br/>
                        @reviewCount
                    </div>
                </div>

                <a href="/"
                   class="block w-full bg-orange-600 text-white font-bold py-4 rounded-2xl text-center hover:opacity-90 transition">
                    Yeni Arama Yap
                </a>

            </div>
        </div>

    </section>

</main>

<footer class="bg-[#0F172A] text-white pt-16 pb-8">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
            <div>
                <div class="text-2xl font-bold tracking-tight mb-6 flex items-center gap-2">
                    <span class="bg-white text-[#0F172A] p-1 rounded">Tx</span>
                    <span class="text-white">Travix</span>
                </div>

                <p class="text-slate-400 text-sm leading-relaxed">
                    Dünyanın en seçkin otellerini en avantajlı fiyatlarla keşfedin. Travix ile lüks seyahat artık daha erişilebilir.
                </p>
            </div>

            <div>
                <h5 class="text-white font-bold mb-6">Şirket</h5>
                <ul class="space-y-4 text-sm text-slate-400">
                    <li><a class="hover:text-orange-500 transition-colors" href="#">Hakkımızda</a></li>
                    <li><a class="hover:text-orange-500 transition-colors" href="#">Kariyer</a></li>
                    <li><a class="hover:text-orange-500 transition-colors" href="#">Blog</a></li>
                    <li><a class="hover:text-orange-500 transition-colors" href="#">Basın</a></li>
                </ul>
            </div>

            <div>
                <h5 class="text-white font-bold mb-6">Destek</h5>
                <ul class="space-y-4 text-sm text-slate-400">
                    <li><a class="hover:text-orange-500 transition-colors" href="#">Yardım Merkezi</a></li>
                    <li><a class="hover:text-orange-500 transition-colors" href="#">Güvenli Ödeme</a></li>
                    <li><a class="hover:text-orange-500 transition-colors" href="#">İptal Koşulları</a></li>
                    <li><a class="hover:text-orange-500 transition-colors" href="#">Bize Ulaşın</a></li>
                </ul>
            </div>

            <div>
                <h5 class="text-white font-bold mb-6">Bültene Katılın</h5>
                <p class="text-sm text-slate-400 mb-4">En özel tekliflerden ilk siz haberdar olun.</p>

                <div class="flex gap-2">
                    <input class="bg-slate-800 text-white placeholder:text-slate-500 border-none rounded-lg px-4 py-2 text-sm w-full focus:ring-1 focus:ring-orange-500"
                           placeholder="E-posta adresiniz"
                           type="email" />

                    <button class="bg-orange-600 text-white px-4 py-2 rounded-lg font-bold text-sm hover:opacity-90 transition-all">
                        Katıl
                    </button>
                </div>
            </div>
        </div>

        <div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-500">
            <p>© 2026 Travix Travel Technologies. Tüm hakları saklıdır.</p>

            <div class="flex gap-6">
                <a class="hover:text-white" href="#">Gizlilik Politikası</a>
                <a class="hover:text-white" href="#">Kullanım Şartları</a>
                <a class="hover:text-white" href="#">KVKK Aydınlatma Metni</a>
            </div>
        </div>
    </div>
</footer>

</body>
</html>