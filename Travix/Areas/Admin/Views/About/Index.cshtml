@model IEnumerable<Travix.Dtos.AdminDtos.AboutDtos.ResultAboutDto>

@{
    Layout = "~/Views/Admin/Index.cshtml";
}

<div class="flex justify-between items-end mb-8">
    <div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface">Hakkımızda Yönetimi</h2>
        <p class="text-body-md text-on-surface-variant mt-2">Hakkımızda sayfası içeriklerini buradan yönetin.</p>
    </div>
    <a asp-action="Create" class="bg-primary-container text-white px-6 py-3 rounded-xl font-label-bold flex items-center gap-2 hover:opacity-90">
        <span class="material-symbols-outlined">add_circle</span>
        Yeni İçerik Ekle
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden border border-slate-100">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-low border-b border-slate-100">
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase tracking-wider">ID</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase tracking-wider">Görsel</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase tracking-wider">Başlık</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase tracking-wider">Açıklama</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase tracking-wider">Özellikler</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase tracking-wider">Durum</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase tracking-wider text-right">İşlemler</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-surface-container-lowest transition-colors group">
                        <td class="px-6 py-4 font-label-bold">#@item.AboutId</td>
                        <td class="px-6 py-4">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Title"
                                     class="w-14 h-10 object-cover rounded-lg border border-slate-100" />
                            }
                            else
                            {
                                <div class="w-14 h-10 bg-surface-container rounded-lg border border-slate-100 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-slate-300 text-[18px]">image</span>
                                </div>
                            }
                        </td>
                        <td class="px-6 py-4">
                            <p class="font-label-bold text-on-surface">@item.Title</p>
                        </td>
                        <td class="px-6 py-4">
                            <p class="text-body-sm text-on-surface-variant truncate max-w-xs">@item.Description</p>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-wrap gap-1">
                                <span class="inline-block px-2 py-1 bg-surface-container text-body-sm rounded-lg border border-slate-100 text-xs">@item.Features1</span>
                                <span class="inline-block px-2 py-1 bg-surface-container text-body-sm rounded-lg border border-slate-100 text-xs">@item.Features2</span>
                                <span class="inline-block px-2 py-1 bg-surface-container text-body-sm rounded-lg border border-slate-100 text-xs">@item.Features3</span>
                                <span class="inline-block px-2 py-1 bg-surface-container text-body-sm rounded-lg border border-slate-100 text-xs">@item.Features4</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            @if (item.IsStatus)
                            {
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-green-50 text-green-700 text-xs font-bold rounded-full border border-green-100">
                                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>Aktif
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-100 text-slate-500 text-xs font-bold rounded-full border border-slate-200">
                                    <span class="w-1.5 h-1.5 bg-slate-400 rounded-full"></span>Pasif
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a asp-action="Update" asp-route-id="@item.AboutId"
                                   class="w-9 h-9 flex items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-600 hover:text-blue-500 hover:border-blue-500 transition-all">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.AboutId"
                                   class="w-9 h-9 flex items-center justify-center rounded-lg bg-white border border-slate-200 text-slate-600 hover:text-error hover:border-error transition-all">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
