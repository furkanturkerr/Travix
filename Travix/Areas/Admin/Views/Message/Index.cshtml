@model List<Travix.Dtos.MessageDtos.ResultMessageDto>

@{
    Layout = "~/Views/Admin/Index.cshtml";
}

<div class="flex justify-between items-end mb-8">
    <div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface">Mesajlar</h2>
        <p class="text-body-md text-on-surface-variant mt-2">
            İletişim formundan gelen mesajları yönetin.
        </p>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm overflow-hidden border border-slate-100">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-low border-b border-slate-100">
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase">ID</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase">Ad Soyad</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase">Email</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase">Konu</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase">Mesaj</th>
                    <th class="px-6 py-4 text-body-sm font-label-bold text-on-surface-variant uppercase">Durum</th>
                    <th class="px-6 py-4 text-right text-body-sm font-label-bold text-on-surface-variant uppercase">İşlem</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-slate-50">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-surface-container-lowest transition group">
                        <td class="px-6 py-4 font-label-bold">#@item.MessageId</td>

                        <td class="px-6 py-4">
                            <p class="font-label-bold text-on-surface">@item.NameSurname</p>
                        </td>

                        <td class="px-6 py-4 text-body-sm text-on-surface-variant">
                            @item.Email
                        </td>

                        <td class="px-6 py-4">
                            <p class="text-body-sm">@item.Subject</p>
                        </td>

                        <td class="px-6 py-4">
                            <p class="text-body-sm text-on-surface-variant truncate max-w-xs">
                                @item.Messages
                            </p>
                        </td>

                        <td class="px-6 py-4">
                            @if (item.IsRead)
                            {
                                <span class="px-3 py-1 bg-green-50 text-green-700 text-xs rounded-full border border-green-100">
                                    Okundu
                                </span>
                            }
                            else
                            {
                                <span class="px-3 py-1 bg-orange-50 text-orange-600 text-xs rounded-full border border-orange-100">
                                    Yeni
                                </span>
                            }
                        </td>

                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition">
                                <a asp-action="Details" asp-route-id="@item.MessageId"
                                   class="w-9 h-9 flex items-center justify-center border rounded-lg hover:text-blue-500">
                                    <span class="material-symbols-outlined">visibility</span>
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.MessageId"
                                   class="w-9 h-9 flex items-center justify-center border rounded-lg hover:text-red-500">
                                    <span class="material-symbols-outlined">delete</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>