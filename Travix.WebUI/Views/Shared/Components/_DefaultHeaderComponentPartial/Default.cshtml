@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}

<header class="fixed top-0 w-full z-50 bg-white/95 backdrop-blur-md border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-8">
            <a class="flex items-center gap-2 group" href="#">
                <div class="w-10 h-10 bg-slate-900 rounded-xl flex items-center justify-center text-white group-hover:rotate-6 transition-transform">
                    <span class="material-symbols-outlined">explore</span>
                </div>
                <span class="text-2xl font-bold tracking-tight text-slate-900 font-display-xl">Travix.WebUI</span>
            </a>
            <nav class="hidden md:flex items-center space-x-6 text-sm font-medium text-slate-600">
                <a asp-controller="Default"
                   asp-action="Index"
                   class="@(controller == "Default"
                              ? "text-slate-900 font-semibold border-b-2 border-secondary pb-1"
                              : "hover:text-slate-900 transition-colors")">
                    Ana Sayfa
                </a>

                <a asp-controller="About"
                   asp-action="Index"
                   class="@(controller == "About"
                              ? "text-slate-900 font-semibold border-b-2 border-secondary pb-1"
                              : "hover:text-slate-900 transition-colors")">
                    Hakkımızda
                </a>

                <a asp-controller="Hotel"
                   asp-action="Index"
                   class="@(controller == "Hotel"
                              ? "text-slate-900 font-semibold border-b-2 border-secondary pb-1"
                              : "hover:text-slate-900 transition-colors")">
                    Oteller
                </a>

                <a asp-controller="Blog"
                   asp-action="Index"
                   class="@(controller == "Blog"
                              ? "text-slate-900 font-semibold border-b-2 border-secondary pb-1"
                              : "hover:text-slate-900 transition-colors")">
                    Blog
                </a>

                <a asp-controller="Contact"
                   asp-action="Index"
                   class="@(controller == "Contact"
                              ? "text-slate-900 font-semibold border-b-2 border-secondary pb-1"
                              : "hover:text-slate-900 transition-colors")">
                    İletişim
                </a>
            </nav>
        </div>
        <div class="flex items-center gap-4">
            <button class="text-slate-600 font-semibold px-4 py-2 hover:bg-slate-100 rounded-lg transition-colors">Giriş Yap</button>
            <button class="bg-slate-900 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-slate-800 transition-all shadow-md active:scale-95">Kayıt Ol</button>
        </div>
    </div>
</header>