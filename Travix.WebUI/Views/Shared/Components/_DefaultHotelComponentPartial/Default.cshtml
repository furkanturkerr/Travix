@model List<Travix.Dtos.Hotel>

<section class="py-xl bg-slate-50">
    <div class="max-w-7xl mx-auto px-8">

        <div class="text-center mb-lg">
            <h2 class="text-headline-lg font-headline-lg text-slate-900">
                Öne Çıkan Oteller
            </h2>

            <p class="text-body-lg text-slate-500 mt-3">
                Ayarlardan belirlenen şehre göre listelenen oteller.
            </p>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-4 gap-gutter">
                @foreach (var item in Model.Take(8))
                {
                    var property = item.property;
                    var image = property?.photoUrls?.FirstOrDefault();

                    if (string.IsNullOrEmpty(image))
                    {
                        image = "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&q=80&w=800";
                    }

                    <div class="bg-white rounded-card overflow-hidden hotel-card-shadow group border border-slate-100 flex flex-col h-full">

                        <div class="relative h-64 overflow-hidden">
                            <img src="@image"
                                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                 alt="@property?.name" />

                            <div class="absolute top-4 right-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold flex items-center shadow-sm">
                                <span class="material-symbols-outlined text-secondary-container text-sm mr-1"
                                      style="font-variation-settings: 'FILL' 1;">
                                    star
                                </span>
                                @property?.reviewScore
                            </div>
                        </div>

                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="text-headline-md font-headline-md text-slate-900 mb-1">
                                @property?.name
                            </h3>

                            <div class="flex items-center text-slate-500 text-body-sm mb-4">
                                <span class="material-symbols-outlined text-sm mr-1">location_on</span>
                                Otel konumu
                            </div>

                            <div class="mt-auto pt-4 border-t border-slate-100 flex justify-between items-center">
                                <div>
                                    <span class="text-xs font-bold text-slate-400 block uppercase tracking-tight">
                                        Fiyat
                                    </span>

                                    <span class="text-headline-md font-headline-md text-secondary">
                                        @(property?.priceBreakdown?.grossPrice?.value?.ToString("0") ?? "Fiyat yok")
                                        @property?.priceBreakdown?.grossPrice?.currency
                                    </span>
                                </div>

                                <a href="/Hotel/Details?id=@property?.id"
                                   class="bg-slate-900 text-white p-3 rounded-xl hover:bg-slate-800 transition-colors">
                                    <span class="material-symbols-outlined">arrow_forward_ios</span>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-card p-10 text-center border border-slate-100 hotel-card-shadow">
                <h3 class="text-xl font-bold text-slate-900 mb-2">
                    Otel bulunamadı
                </h3>

                <p class="text-slate-500">
                    Admin panelinden anasayfa otel şehir ayarını değiştirebilirsin.
                </p>
            </div>
        }

    </div>
</section>