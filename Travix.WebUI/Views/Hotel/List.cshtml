@model List<Travix.Dtos.Hotel>

@{
    Layout = null;

    var city = ViewBag.City;
    var checkIn = ViewBag.CheckIn;
    var checkOut = ViewBag.CheckOut;
    var adults = ViewBag.Adults;
    var room = ViewBag.Room;
    var currency = ViewBag.Currency;
    var language = ViewBag.Language;
    var minPrice = ViewBag.MinPrice ?? "";
    var maxPrice = ViewBag.MaxPrice ?? "";
    var totalHotel = Model?.Count ?? 0;
    
}

<!DOCTYPE html>
<html lang="tr">
@await Component.InvokeAsync("_ListHeadComponentPartial")

<body class="bg-[#F8FAFC]">

@await Component.InvokeAsync("_DefaultHeaderComponentPartial")
<section class="sticky top-20 z-40 bg-white border-b border-[#e4e2e4] py-4">
    <div class="max-w-[1280px] mx-auto px-6">
        <form method="post" asp-controller="Hotel" asp-action="List"
              class="bg-white rounded-2xl p-2 flex flex-wrap lg:flex-nowrap items-center gap-2 border border-[#c6c6cd] shadow-lg">

            <div class="flex-1 flex items-center gap-4 px-5 border-r border-[#c6c6cd] min-h-[64px]">
                <span class="material-symbols-outlined text-black text-2xl">location_on</span>
                <div class="flex flex-col w-full">
                    <span class="text-[10px] uppercase font-bold text-[#45464d] tracking-wider">Şehir</span>
                    <input name="city"
                           type="text"
                           value="@city"
                           class="bg-transparent border-none p-0 focus:ring-0 font-semibold text-black w-full"/>
                </div>
            </div>

            <div class="flex-[1.2] flex items-center gap-4 px-5 border-r border-[#c6c6cd] min-h-[64px]">
                <span class="material-symbols-outlined text-black text-2xl">calendar_month</span>
                <div class="flex flex-col w-full">
                    <span class="text-[10px] uppercase font-bold text-[#45464d] tracking-wider">Giriş - Çıkış</span>
                    <div class="flex gap-2 items-center">
                        <input name="checkIn"
                               type="date"
                               value="@checkIn"
                               class="bg-transparent border-none p-0 focus:ring-0 font-semibold text-black w-[135px]"/>
                        <span class="text-[#76777d]">/</span>
                        <input name="checkOut"
                               type="date"
                               value="@checkOut"
                               class="bg-transparent border-none p-0 focus:ring-0 font-semibold text-black w-[135px]"/>
                    </div>
                </div>
            </div>

            <div class="flex-1 flex items-center gap-4 px-5 border-r border-[#c6c6cd] min-h-[64px]">
                <span class="material-symbols-outlined text-black text-2xl">group</span>
                <div class="flex flex-col w-full">
                    <span class="text-[10px] uppercase font-bold text-[#45464d] tracking-wider">Misafir / Oda</span>
                    <div class="flex items-center gap-2">
                        <input name="adults"
                               type="number"
                               min="1"
                               value="@adults"
                               class="bg-transparent border-none p-0 focus:ring-0 font-semibold text-black w-12"/>
                        <span class="font-semibold text-black">Yetişkin,</span>
                        <input name="room"
                               type="number"
                               min="1"
                               value="@room"
                               class="bg-transparent border-none p-0 focus:ring-0 font-semibold text-black w-10"/>
                        <span class="font-semibold text-black">Oda</span>
                    </div>
                </div>
            </div>

            <div class="flex-[0.7] flex items-center gap-4 px-5 border-r border-[#c6c6cd] min-h-[64px]">
                <div class="flex flex-col w-full">
                    <span class="text-[10px] uppercase font-bold text-[#45464d] tracking-wider">Para / Dil</span>
                    <div class="flex items-center gap-2">
                        <select name="currency"
                                class="bg-transparent border-none p-0 focus:ring-0 font-semibold text-black w-[70px]">
                            <option value="USD" selected="@(currency == "USD")">USD</option>
                            <option value="AED" selected="@(currency == "AED")">AED</option>
                            <option value="EUR" selected="@(currency == "EUR")">EUR</option>
                            <option value="TRY" selected="@(currency == "TRY")">TRY</option>
                        </select>

                        <input type="hidden" name="language" value="en-us"/>
                        <span class="font-semibold text-black">Türkçe</span>
                    </div>
                </div>
            </div>

            <input type="hidden" name="minPrice" value="@minPrice"/>
            <input type="hidden" name="maxPrice" value="@maxPrice"/>

            <button type="submit"
                    class="bg-[#fea619] text-[#684000] px-10 py-4 rounded-xl font-semibold hover:brightness-95 active:scale-95 transition-all">
                Ara
            </button>
        </form>
    </div>
</section>

<main class="max-w-[1280px] mx-auto px-6 pt-[8rem] pb-[3rem]">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
        <div>
            <h1 class="serif text-black text-4xl font-black mb-3">
                @city için @totalHotel otel bulundu
            </h1>

            <div class="flex flex-wrap items-center gap-3">
                <span class="text-[#45464d] text-sm">Seçili filtreler:</span>

                <span class="bg-[#f0edef] text-black px-3 py-1 rounded-full text-xs font-semibold">
                    @checkIn / @checkOut
                </span>

                <span class="bg-[#f0edef] text-black px-3 py-1 rounded-full text-xs font-semibold">
                    @adults Yetişkin
                </span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

        <aside class="lg:col-span-3 space-y-6 sticky top-52">

            <div class="bg-white rounded-2xl p-6 border border-[#e4e2e4] shadow-sm">
                <h3 class="font-semibold text-black mb-4 border-b border-[#e4e2e4] pb-3">
                    Arama Özeti
                </h3>

                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-[#45464d] text-xl">location_on</span>
                        <span class="text-[#45464d]">@city, İtalya</span>
                    </div>

                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-[#45464d] text-xl">calendar_today</span>
                        <span class="text-[#45464d]">@checkIn - @checkOut</span>
                    </div>

                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-[#45464d] text-xl">person</span>
                        <span class="text-[#45464d]">@adults Yetişkin, @room Oda</span>
                    </div>
                </div>
            </div>

            <form method="post" asp-controller="Hotel" asp-action="List"
                  class="bg-white rounded-2xl p-6 border border-[#e4e2e4] shadow-sm">

                <h3 class="font-semibold text-black mb-4 border-b border-[#e4e2e4] pb-3">
                    Fiyat Aralığı
                </h3>

                <input type="hidden" name="city" value="@city"/>
                <input type="hidden" name="checkIn" value="@checkIn"/>
                <input type="hidden" name="checkOut" value="@checkOut"/>
                <input type="hidden" name="adults" value="@adults"/>
                <input type="hidden" name="currency" value="@currency"/>
                <input type="hidden" name="language" value="en-us"/>
                <input type="hidden" name="room" value="@room"/>

                <div class="space-y-4">
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="text-[10px] font-bold text-[#45464d] block mb-1 uppercase tracking-wider">
                                Min (@currency)
                            </label>
                            <input name="minPrice"
                                   type="number"
                                   value="@minPrice"
                                   class="w-full bg-[#f6f3f5] border border-[#c6c6cd] rounded-lg p-3 font-semibold focus:ring-2 focus:ring-[#fea619] transition"/>
                        </div>

                        <div>
                            <label class="text-[10px] font-bold text-[#45464d] block mb-1 uppercase tracking-wider">
                                Max (@currency)
                            </label>
                            <input name="maxPrice"
                                   type="number"
                                   value="@maxPrice"
                                   class="w-full bg-[#f6f3f5] border border-[#c6c6cd] rounded-lg p-3 font-semibold focus:ring-2 focus:ring-[#fea619] transition"/>
                        </div>
                    </div>

                    <button type="submit"
                            class="w-full bg-[#0F172A] text-white py-3 rounded-lg font-semibold hover:opacity-90 transition">
                        Filtrele
                    </button>

                    <a href="/" class="block text-center text-[#45464d] py-2 font-semibold hover:text-black transition text-sm">
                        Temizle
                    </a>
                </div>
            </form>

        </aside>

        <div class="lg:col-span-9 space-y-6">

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    var property = item.property;
                    var image = property?.photoUrls?.FirstOrDefault();
                    var hotelName = property?.name ?? "Otel adı bulunamadı";
                    var score = property?.reviewScore ?? 0;
                    var scoreWord = property?.reviewScoreWord ?? "Çok iyi";
                    var reviewCount = property?.reviewCount ?? 0;
                    var price = property?.priceBreakdown?.grossPrice?.value ?? 0;
                    var priceCurrency = property?.priceBreakdown?.grossPrice?.currency ?? currency;
                    var starCount = property?.propertyClass ?? property?.accuratePropertyClass ?? 4;
                    var description = $"{hotelName}, {city} bölgesinde yer alan {scoreWord.ToLower()} değerlendirmeye sahip bir konaklama seçeneğidir. Fiyat, konum ve kullanıcı puanına göre seyahat planınız için değerlendirilebilir.";


                    if (string.IsNullOrEmpty(image))
                    {
                        image = "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&q=80&w=800";
                    }

                    if (starCount <= 0) starCount = 4;
                    if (starCount > 5) starCount = 5;

                    <div class="bg-white rounded-[20px] border border-[#e4e2e4] overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.05)] hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row h-auto md:h-64">

                        <div class="md:w-[35%] relative overflow-hidden h-52 md:h-full">
                            <img class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
                                 src="@image"
                                 alt="@hotelName"/>

                            @if (property?.isPreferred == true)
                            {
                                <span class="absolute top-4 left-4 bg-black text-white px-3 py-1 rounded-full text-xs font-semibold shadow-lg">
                                    Popüler
                                </span>
                            }
                        </div>

                        <div class="md:w-[40%] p-6 flex flex-col justify-between">
                            <div>
                                <div class="flex items-center gap-1 mb-2">
                                    @for (int i = 0; i < starCount; i++)
                                    {
                                        <span class="material-symbols-outlined text-[#fea619] text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                                    }
                                </div>

                                <h3 class="serif text-black text-2xl font-bold mb-2">
                                    @hotelName
                                </h3>

                                <div class="flex items-center gap-1 text-[#45464d] text-sm mb-4">
                                    <span class="material-symbols-outlined text-base">location_on</span>
                                    @city, İtalya
                                </div>

                                <p class="text-[#45464d] text-base leading-relaxed mb-4 line-clamp-2">
                                    @description
                                </p>

                                <div class="flex flex-wrap gap-2">
                                    <span class="bg-[#f0edef] text-[#45464d] px-2 py-1 rounded text-[10px] font-bold uppercase">WiFi</span>
                                    <span class="bg-[#f0edef] text-[#45464d] px-2 py-1 rounded text-[10px] font-bold uppercase">Kahvaltı</span>
                                    <span class="bg-[#f0edef] text-[#45464d] px-2 py-1 rounded text-[10px] font-bold uppercase">Merkezi Konum</span>
                                </div>
                            </div>
                        </div>

                        <div class="md:w-[25%] p-6 bg-[#FAFAFA] border-l border-[#e4e2e4] flex flex-col justify-between items-end text-right">
                            <div class="flex flex-col items-end">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="font-semibold text-black">@scoreWord</span>

                                    @if (score > 0)
                                    {
                                        <span class="bg-[#0F172A] text-white px-2 py-1 rounded text-sm font-bold">
                                            @score
                                        </span>
                                    }
                                </div>

                                <span class="text-xs text-[#45464d]">
                                    @reviewCount yorum
                                </span>
                            </div>

                            <div class="w-full">
                                <span class="block text-4xl font-black text-black">
                                    @price.ToString("0") @priceCurrency
                                </span>

                                <span class="block text-xs text-[#45464d] mb-4">
                                    Vergiler hariç
                                </span>

                                <a href="/Hotel/Details?id=@property?.id&checkIn=@checkIn&checkOut=@checkOut"
                                   class="block w-full text-center bg-[#fea619] text-[#684000] py-3 rounded-xl font-semibold hover:shadow-md transition active:scale-95">
                                    Detayları Gör
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="bg-white rounded-[20px] border border-[#e4e2e4] p-16 text-center shadow-sm">
                    <span class="material-symbols-outlined text-6xl text-[#45464d] mb-4">travel_explore</span>
                    <h3 class="serif text-black text-2xl font-bold mb-2">Otel bulunamadı</h3>
                    <p class="text-[#45464d]">Arama bilgilerini değiştirip tekrar deneyebilirsin.</p>
                </div>
            }

        </div>
    </div>
</main>

@await Component.InvokeAsync("_DefaultFooterComponentPartial")

</body>
</html>